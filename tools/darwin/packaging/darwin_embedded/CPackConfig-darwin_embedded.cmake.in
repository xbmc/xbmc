set(CPACK_GENERATOR "@DARWIN_EMBEDDED_CPACK_GENERATOR@")
set(CPACK_PACKAGE_NAME "@DARWIN_EMBEDDED_CPACK_PACKAGE_NAME@")
set(CPACK_PACKAGE_VENDOR "Team-@APP_NAME@")
set(CPACK_PACKAGE_CONTACT "Memphiz et al.")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "@APP_NAME@ Entertainment Center for @DARWIN_EMBEDDED_DEVICE@")
set(CPACK_PACKAGE_DESCRIPTION "@APP_NAME@ Entertainment Center for @DARWIN_EMBEDDED_DEVICE@")
set(CPACK_PACKAGE_HOMEPAGE_URL "@APP_WEBSITE@")
set(CPACK_PACKAGE_VERSION "@DARWIN_EMBEDDED_VERSION@")
set(CPACK_PACKAGE_FILE_NAME "@DARWIN_EMBEDDED_CPACK_FILE_NAME@")
set(CPACK_PACKAGE_DIRECTORY "@DARWIN_EMBEDDED_CPACK_DIR@")
set(CPACK_INCLUDE_TOPLEVEL_DIRECTORY OFF)

# Keep the public deb/ipa targets thin: CPack owns archive creation while this
# install script only stages the platform-specific bundle layout.
set(CPACK_INSTALL_COMMANDS
    "${CMAKE_COMMAND} -DCPACK_BUILD_CONFIG=${CPACK_BUILD_CONFIG} -DDARWIN_EMBEDDED_CPACK_KIND=@DARWIN_EMBEDDED_CPACK_KIND@ -P @DARWIN_EMBEDDED_CPACK_DIR@/cpack_install-darwin_embedded.cmake")

if(CPACK_GENERATOR STREQUAL "DEB")
  set(CPACK_DEBIAN_PACKAGE_NAME "@DARWIN_EMBEDDED_PACKAGE_ARM64@")
  set(CPACK_DEBIAN_FILE_NAME "@DARWIN_EMBEDDED_CPACK_FILE_NAME@.deb")
  set(CPACK_DEBIAN_PACKAGE_VERSION "@DARWIN_EMBEDDED_VERSION@-@DARWIN_EMBEDDED_REVISION@")
  set(CPACK_DEBIAN_PACKAGE_ARCHITECTURE "@DARWIN_EMBEDDED_DEB_ARCHITECTURE@")
  set(CPACK_DEBIAN_PACKAGE_DESCRIPTION "@APP_NAME@ Entertainment Center for @DARWIN_EMBEDDED_DEVICE@")
  set(CPACK_DEBIAN_PACKAGE_MAINTAINER "Memphiz et al.")
  set(CPACK_DEBIAN_PACKAGE_HOMEPAGE "@APP_WEBSITE@")
  set(CPACK_DEBIAN_PACKAGE_SECTION "Multimedia")
  set(CPACK_DEBIAN_PACKAGE_PRIORITY "Extra")
  set(CPACK_DEBIAN_PACKAGE_PREDEPENDS "cy+cpu.arm64")
  set(CPACK_DEBIAN_PACKAGE_CONFLICTS "@DARWIN_EMBEDDED_PACKAGE@")
  set(CPACK_DEBIAN_PACKAGE_REPLACES "@DARWIN_EMBEDDED_PACKAGE@")
  set(CPACK_DEBIAN_PACKAGE_CONTROL_EXTRA
      "@DARWIN_EMBEDDED_CPACK_DIR@/prerm;@DARWIN_EMBEDDED_CPACK_DIR@/postinst")
  set(CPACK_DEBIAN_PACKAGE_CONTROL_STRICT_PERMISSION TRUE)
  set(CPACK_DEBIAN_COMPRESSION_TYPE "xz")
elseif(CPACK_GENERATOR STREQUAL "ZIP")
  set(CPACK_ARCHIVE_FILE_EXTENSION "ipa")
endif()
