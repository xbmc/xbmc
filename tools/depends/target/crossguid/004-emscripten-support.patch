--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -26,6 +26,8 @@ elseif(APPLE)
     find_library(CFLIB CoreFoundation)
     target_link_libraries(crossguid ${CFLIB})
     target_compile_definitions(crossguid PRIVATE GUID_CFUUID)
+elseif(EMSCRIPTEN)
