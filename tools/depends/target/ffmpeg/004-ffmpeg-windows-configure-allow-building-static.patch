From 3e72cabeaea5eb952823989703aa98c44444f687 Mon Sep 17 00:00:00 2001
From: Lukas Rusak <lorusak@gmail.com>
Date: Sat, 10 Apr 2021 08:17:11 -0700
Subject: [PATCH] ffmpeg: windows: configure: allow building static

---
 configure | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/configure b/configure
index ab1c0e1e78..e00e3a8c96 100755
--- a/configure
+++ b/configure
@@ -6152,6 +6152,8 @@ case $target_os in
         enabled x86_32 && check_ldflags -Wl,--large-address-aware
         add_cppflags -DWIN32_LEAN_AND_MEAN
         shlibdir_default="$bindir_default"
+        LIBPREF=""
+        LIBSUF=".lib"
         SLIBPREF=""
         SLIBSUF=".dll"
         SLIBNAME_WITH_VERSION='$(SLIBPREF)$(FULLNAME)-$(LIBVERSION)$(SLIBSUF)'
@@ -6203,6 +6205,7 @@ case $target_os in
         add_cppflags -DWIN32_LEAN_AND_MEAN
         shlibdir_default="$bindir_default"
         LIBPREF=""
+        LIBSUF=".lib"
         SLIBPREF=""
         SLIBSUF=".dll"
         SLIBNAME_WITH_VERSION='$(SLIBPREF)$(FULLNAME)-$(LIBVERSION)$(SLIBSUF)'
-- 
2.49.0

