diff --git a/src/tz.cpp b/src/tz.cpp
index 1592bc8..86680a5 100644
--- a/src/tz.cpp
+++ b/src/tz.cpp
@@ -2669,16 +2669,16 @@ find_read_and_leap_seconds()
