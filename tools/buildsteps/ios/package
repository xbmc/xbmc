WORKSPACE=${WORKSPACE:-$( cd $(dirname $0)/../../.. ; pwd -P )}
XBMC_PLATFORM_DIR=ios
. $WORKSPACE/tools/buildsteps/defaultenv

cd $WORKSPACE/build/tools/darwin/packaging/darwin_embedded/

#rename for upload
#e.x. kodi-${JENKINS_BUILD_STRING}-ios64.deb
#e.x. kodi-${JENKINS_BUILD_STRING}-ios64.ipa
UPLOAD_DIR="$WORKSPACE/tools/darwin/packaging/ios"
UPLOAD_FILENAME="kodi-$(getBuildRevDateStr)-ios64"
mkdir -p $UPLOAD_DIR
mv *.deb $UPLOAD_DIR/$UPLOAD_FILENAME.deb
mv *.ipa $UPLOAD_DIR/$UPLOAD_FILENAME.ipa
