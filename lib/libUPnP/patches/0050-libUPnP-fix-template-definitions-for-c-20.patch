     {
         Item* item = m_Head;
         while (item) {
@@ -187,39 +192,43 @@ public:
 
     // Merge sort algorithm
     // http://en.wikipedia.org/wiki/Mergesort
-    template <typename X> 
+    template<typename X>
     NPT_Result Sort(const X& function)
-    {   
-        if (GetItemCount() <= 1) return NPT_SUCCESS;
-        
-        NPT_List<T> right;
-        NPT_CHECK(Cut(GetItemCount() >> 1, right));
-        
-        // sort the left side
-        Sort(function);
-        
-        // sort the right side
-        right.Sort(function);
-        
-        // merge the two back inline
-        if (function(m_Tail->m_Data, right.m_Head->m_Data) > 0) {
-            Merge(right, function);
-        } else {
-            // append right
-            right.m_Head->m_Prev = m_Tail;
-            m_Tail->m_Next = right.m_Head;
-            m_Tail = right.m_Tail;
-            m_ItemCount += right.m_ItemCount;
-            
-            right.m_ItemCount = 0;
-            right.m_Head = right.m_Tail = NULL;
-        }
-        
+    {
+      if (GetItemCount() <= 1)
         return NPT_SUCCESS;
+
+      NPT_List<T> right;
+      NPT_CHECK(Cut(GetItemCount() >> 1, right));
+
+      // sort the left side
+      Sort(function);
+
+      // sort the right side
+      right.Sort(function);
+
+      // merge the two back inline
+      if (function(m_Tail->m_Data, right.m_Head->m_Data) > 0)
+      {
+        Merge(right, function);
+      }
+      else
+      {
+        // append right
+        right.m_Head->m_Prev = m_Tail;
+        m_Tail->m_Next = right.m_Head;
+        m_Tail = right.m_Tail;
+        m_ItemCount += right.m_ItemCount;
+
+        right.m_ItemCount = 0;
+        right.m_Head = right.m_Tail = NULL;
+      }
+
+      return NPT_SUCCESS;
     }
 
